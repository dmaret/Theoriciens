<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PraxisPro Épistémé</title>
    
    <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 text-gray-800 font-sans">
    
    <div id="root"></div>

    <script type="text/babel">
        const { useState } = React;

        const App = () => {
          const [activeTab, setActiveTab] = useState('generateur');
          const [symptomesCoches, setSymptomesCoches] = useState([]);

          const symptomesList = [
            { id: 'S1', label: 'Mutisme ou retrait lors des entretiens' },
            { id: 'S2', label: 'Échecs répétés à la dernière étape de recrutement' },
            { id: 'S3', label: 'Refus catégorique de se former' },
            { id: 'S4', label: 'Sabotage des démarches (retards, oublis)' },
            { id: 'S5', label: 'Sur-adaptation (dit "oui" à tout mais ne fait rien)' }
          ];

          const genererHypotheses = () => {
            if (symptomesCoches.length === 0) return null;

            return (
              <div className="space-y-6 mt-6">
                <div className="bg-purple-50 border-l-4 border-purple-500 p-5 rounded-r-xl">
                  <h4 className="font-bold text-purple-900 flex items-center gap-2 mb-2">
                    🧠 Hypothèse Systémique (Palo Alto, Minuchin)
                  </h4>
                  <p className="text-sm text-purple-800 mb-2">
                    <strong>Tentative de solution & Homéostasie :</strong> Le comportement ne doit pas être vu comme un déficit, mais comme une solution dysfonctionnelle. Selon <em>Watzlawick et Weakland</em>, l'injonction à "trouver un emploi à tout prix" peut constituer une double contrainte si le système familial (<em>Minuchin</em>) dépend de la présence du bénéficiaire.
                  </p>
                  <div className="bg-white p-3 rounded shadow-sm text-sm">
                    <strong>Piste d'action (Haley) :</strong> Prescrire le symptôme ("Pour la semaine prochaine, je vous demande de ne faire aucune démarche") pour casser la redondance interactionnelle.
                  </div>
                </div>

                <div className="bg-blue-50 border-l-4 border-blue-500 p-5 rounded-r-xl">
                  <h4 className="font-bold text-blue-900 flex items-center gap-2 mb-2">
                    🎯 Hypothèse Identitaire (Piaget, Dubar, Carré)
                  </h4>
                  <p className="text-sm text-blue-800 mb-2">
                    <strong>Apprenance & Crise biographique :</strong> Selon <em>Piaget</em>, le bénéficiaire peine à "accommoder" ses schémas au marché du travail. <em>Claude Dubar</em> indiquerait une rupture entre l'identité pour soi et l'identité pour autrui. Le manque d'apprenance (<em>Philippe Carré</em>) s'explique par cette menace identitaire.
                  </p>
                  <div className="bg-white p-3 rounded shadow-sm text-sm">
                    <strong>Piste d'action (Meirieu / Paul) :</strong> Postulat d'éducabilité. Adopter une posture asymétrique mais non directive (<em>Maela Paul</em>) pour reconstruire le sens.
                  </div>
                </div>

                <div className="bg-gray-800 text-gray-100 border-l-4 border-gray-400 p-5 rounded-r-xl">
                  <h4 className="font-bold text-white flex items-center gap-2 mb-2">
                    🛡️ Cadrage Légal (LACI - Admin.ch)
                  </h4>
                  <p className="text-sm mb-2">
                    <strong>Art. 15 et 17 LACI :</strong> La traçabilité de ces hypothèses cliniques dans le dossier permet d'attester que le défaut de démarche fait l'objet d'un travail de fond, évitant une sanction immédiate pour inaptitude au placement.
                  </p>
                </div>
              </div>
            );
          };

          const RenderGenerateur = () => (
            <div className="space-y-6">
              <div className="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
                <h2 className="text-xl font-bold mb-4 flex items-center gap-2">
                  💡 Générateur d'Hypothèses Cliniques
                </h2>
                <p className="text-gray-600 mb-4 text-sm">
                  Sélectionnez les comportements observés pour générer une grille de lecture (Systémie, Constructivisme, Droit).
                </p>
                
                <div className="grid grid-cols-1 md:grid-cols-2 gap-3 mb-6">
                  {symptomesList.map(sym => (
                    <label key={sym.id} className="flex items-center gap-3 p-3 border rounded-lg cursor-pointer hover:bg-gray-50 transition">
                      <input 
                        type="checkbox" 
                        className="w-5 h-5 text-blue-600 rounded border-gray-300 focus:ring-blue-500"
                        checked={symptomesCoches.includes(sym.id)}
                        onChange={(e) => {
                          if (e.target.checked) {
                            setSymptomesCoches([...symptomesCoches, sym.id]);
                          } else {
                            setSymptomesCoches(symptomesCoches.filter(id => id !== sym.id));
                          }
                        }}
                      />
                      <span className="text-sm font-medium text-gray-700">{sym.label}</span>
                    </label>
                  ))}
                </div>
                {genererHypotheses()}
              </div>
            </div>
          );

          const RenderQuestionnementCirculaire = () => (
            <div className="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
              <h2 className="text-xl font-bold mb-4 flex items-center gap-2">
                👥 Boussole de Questionnement Circulaire
              </h2>
              <p className="text-gray-600 mb-6 text-sm">
                Selon G. Bateson et V. Satir, ces questions décentrent le problème de l'individu vers ses interactions.
              </p>

              <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div className="space-y-4">
                  <h3 className="font-bold text-gray-800 border-b pb-2">Différences de perception</h3>
                  <div className="bg-green-50 p-4 rounded-lg text-sm border border-green-100">
                    <ul className="space-y-3">
                      <li className="flex gap-2">💬 "Selon vous, qui dans votre entourage est le plus inquiet de votre situation ?"</li>
                      <li className="flex gap-2">💬 "Si je demandais à votre conjoint ce qui vous bloque, que me dirait-il ?"</li>
                    </ul>
                  </div>
                </div>

                <div className="space-y-4">
                  <h3 className="font-bold text-gray-800 border-b pb-2">Homéostasie du système</h3>
                  <div className="bg-orange-50 p-4 rounded-lg text-sm border border-orange-100">
                    <ul className="space-y-3">
                      <li className="flex gap-2">💬 "Qu'est-ce qui serait le plus grave : rester dans cette situation, ou réussir et que les attentes changent ?"</li>
                      <li className="flex gap-2">💬 "Si demain vous trouvez le poste idéal, qui dans votre famille devra le plus réorganiser sa vie ?"</li>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          );

          const RenderEvaluateurPosture = () => (
            <div className="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
              <h2 className="text-xl font-bold mb-4 flex items-center gap-2">
                🧭 Évaluateur de Posture Professionnelle
              </h2>
              <p className="text-gray-600 mb-6 text-sm">
                Inspiré de J. Libois (le sensible) et M. Paul (cheminer avec).
              </p>

              <div className="space-y-4">
                <div className="p-4 border border-gray-200 rounded-lg">
                  <h4 className="font-bold text-gray-800">1. Qui définit la finalité du rendez-vous ?</h4>
                  <select className="w-full mt-2 p-2 border rounded text-sm bg-gray-50">
                    <option>Moi, en fonction des exigences légales (Risque de résistance)</option>
                    <option>Co-construction : le cadre est posé, le chemin lui appartient</option>
                  </select>
                </div>

                <div className="p-4 border border-gray-200 rounded-lg">
                  <h4 className="font-bold text-gray-800">2. Quelle place est laissée au "Sensible" ?</h4>
                  <select className="w-full mt-2 p-2 border rounded text-sm bg-gray-50">
                    <option>J'occulte les émotions pour rester rationnel sur l'emploi.</option>
                    <option>J'accueille l'émotion comme une donnée légitime de la transaction biographique (Dubar).</option>
                  </select>
                </div>
              </div>
            </div>
          );

          return (
            <div className="min-h-screen">
              <header className="bg-slate-900 text-white border-b border-gray-800 shadow-lg sticky top-0 z-10">
                <div className="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
                  <div>
                    <h1 className="text-2xl font-black tracking-tight">Praxis<span className="text-blue-400">Pro</span> Épistémé</h1>
                    <p className="text-xs text-gray-300 font-medium mt-1">Ingénierie de l'accompagnement socioprofessionnel</p>
                  </div>
                  <div className="flex gap-2 hidden md:flex">
                    <span className="inline-flex items-center gap-1 px-3 py-1 bg-green-900 text-green-300 border border-green-700 rounded-full text-xs font-bold">
                      🛡️ Sources certifiées (HES-SO / Admin.ch)
                    </span>
                  </div>
                </div>
              </header>

              <main className="max-w-7xl mx-auto px-4 py-8">
                <div className="flex flex-wrap gap-2 mb-8 border-b border-gray-200 pb-2">
                  <button
                    onClick={() => setActiveTab('generateur')}
                    className={`px-4 py-2 rounded-lg font-semibold text-sm transition-colors ${
                      activeTab === 'generateur' ? 'bg-blue-600 text-white shadow' : 'bg-white text-gray-600 hover:bg-gray-50'
                    }`}
                  >
                    💡 Hypothèses
                  </button>
                  <button
                    onClick={() => setActiveTab('questionnement')}
                    className={`px-4 py-2 rounded-lg font-semibold text-sm transition-colors ${
                      activeTab === 'questionnement' ? 'bg-blue-600 text-white shadow' : 'bg-white text-gray-600 hover:bg-gray-50'
                    }`}
                  >
                    👥 Palo Alto
                  </button>
                  <button
                    onClick={() => setActiveTab('posture')}
                    className={`px-4 py-2 rounded-lg font-semibold text-sm transition-colors ${
                      activeTab === 'posture' ? 'bg-blue-600 text-white shadow' : 'bg-white text-gray-600 hover:bg-gray-50'
                    }`}
                  >
                    🧭 Posture
                  </button>
                </div>

                <div className="transition-all duration-300">
                  {activeTab === 'generateur' && <RenderGenerateur />}
                  {activeTab === 'questionnement' && <RenderQuestionnementCirculaire />}
                  {activeTab === 'posture' && <RenderEvaluateurPosture />}
                </div>
              </main>
            </div>
          );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
